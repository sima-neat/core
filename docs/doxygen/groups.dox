/**
 * @defgroup graph Graph runtime
 * @brief Runtime DAG, named-port stages, and execution support behind Graph.
 */

/**
 * @defgroup graph_nodes Runtime graph nodes
 * @ingroup graph
 * @brief Stage, fan-out, join, scheduler, and adapter nodes for runtime graphs.
 */

/**
 * @defgroup graph_runtime Graph runtime queues
 * @ingroup graph
